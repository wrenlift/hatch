# Local-only test variant of the production Dockerfile.
#
# Identical to Dockerfile EXCEPT the wlift-builder stage receives
# the wren_lift source via `--build-context wlift_src=...` instead
# of cloning from github (the local commits aren't pushed yet).
#
# Usage:
#   docker buildx build \
#     --build-context wlift_src=/Users/amaterasu/Vibranium/wren_lift \
#     -f Dockerfile.local-test \
#     -t hatch-site-aot-test:local \
#     .
#
# Delete this file once the AOT fixes land in a tagged wren_lift
# release — the production Dockerfile is the source of truth.

# ---------------------------------------------------------------
FROM rust:1-trixie AS wlift-builder

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates pkg-config cmake build-essential \
    && rm -rf /var/lib/apt/lists/*

# Local source from the build context. The .dockerignore on the
# wren_lift side excludes target/ so we don't ship 5 GB of cargo
# artefacts into the image.
COPY --from=wlift_src . /src
WORKDIR /src

# `--lib` is needed alongside the bins so the lib crate's
# `staticlib` crate-type produces `libwren_lift.a` — without it,
# cargo only emits the `rlib` the bins actually need to link
# against, and the bundle stage's COPY fails. Building all three
# in one invocation reuses the same target dir.
RUN cargo build --release --features aot --bin wlift --bin hatch --lib

# ---------------------------------------------------------------
FROM debian:trixie-slim AS bundle

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates curl bash build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY --from=wlift-builder /src/target/release/wlift            /usr/local/bin/wlift
COPY --from=wlift-builder /src/target/release/hatch            /usr/local/bin/hatch
COPY --from=wlift-builder /src/target/release/libwren_lift.a   /usr/local/bin/libwren_lift.a

WORKDIR /build
COPY hatchfile main.wren ./
COPY lib    ./lib
COPY views  ./views
COPY public ./public
COPY content ./content

RUN hatch build . --out site.hatch
RUN wlift --aot ./site ./site.hatch

# ---------------------------------------------------------------
FROM debian:trixie-slim AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=bundle /build/site     ./site
COPY --from=bundle /build/views    ./views
COPY --from=bundle /build/content  ./content
COPY --from=bundle /build/public   ./public

ENV PORT=3000
EXPOSE 3000

CMD ["./site"]
