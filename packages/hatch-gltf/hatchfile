name        = "@hatch:gltf"
version     = "0.1.3"
entry       = "gltf"
description = "Pure-Wren glTF 2.0 / .glb loader. Parses the binary container into nodes / meshes / materials, resolves accessors into typed vertex + index arrays (Float32Array / Int32Array / ByteArray), decodes embedded images via @hatch:image, and spawns a Transform-rooted hierarchy into a `@hatch:ecs` World with fully-textured PBR `Material`s wired to every glTF slot (baseColor / metallicRoughness / normal / occlusion / emissive)."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:gltf"
readme   = "README.md"
changelog = "CHANGELOG.md"

# Dual-form deps — `path` is tried first (workspace dev), and the
# resolver falls back to the registry `version` pin when the path
# doesn't exist (downstream registry consumers).
[dependencies]
"@hatch:json"  = "0.1.6"
"@hatch:math"  = { path = "../hatch-math",  version = "0.1.5" }
"@hatch:ecs"   = { path = "../hatch-ecs",   version = "0.2.4" }
"@hatch:gpu"   = { path = "../hatch-gpu",   version = "0.3.22" }
"@hatch:image" = { path = "../hatch-image", version = "0.1.8" }
"@hatch:game"  = { path = "../hatch-game",  version = "0.3.37" }

[spec-dependencies]
"@hatch:test" = "0.2.1"
"@hatch:assert" = "0.2.3"
