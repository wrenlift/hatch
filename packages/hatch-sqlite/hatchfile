name        = "@hatch:sqlite"
version     = "0.1.3"
entry       = "sqlite"
description = "Embedded SQLite. `Database.open(path)` returns a connection; prepared statements with named parameter binding, rows iterated as Maps, transactions, error handling. Backed by rusqlite (bundled libsqlite — no system dependency)."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:sqlite"
readme   = "README.md"

# Search path for spec / dev runs — the CI workflow drops
# cross-built dylibs here before `hatch publish`.
native_search_paths = ["libs"]

# Where the dylib's source lives. The runtime doesn't touch this
# field; the hatch-repo CI workflow (`.github/workflows/publish.yml`)
# consumes it: clone `repo` at `rev`, run `cargo build -p <crate>
# --release` across a platform matrix, copy each resulting
# library into `libs/` below, then bundle via `hatch publish`.
#
# Pinning is per package version — bump `rev` whenever you need
# a newer runtime surface. Consumers of `@hatch:sqlite@0.1.0` will
# always get the dylib built from exactly this SHA.

[plugin_source]
repo  = "https://github.com/wrenlift/WrenLift.git"
rev   = "c13644d948883432bbb873309e69d3801e66e6d7"
crate = "wlift_sqlite"

# Per-platform dylib paths. CI populates `libs/` via the
# plugin_source build; local dev can also run the build directly:
#
#     cargo build -p wlift_sqlite --release
#     cp target/release/libwlift_sqlite.dylib \
#        hatch/packages/hatch-sqlite/libs/
#
# At publish time `pack_bundled_native_libs` picks the host
# platform's entry, embeds its bytes as a `NativeLib` section,
# and strips this manifest entry — downstream consumers load the
# dylib from the bundled bytes, not the filesystem.

[native_libs.wlift_sqlite]
# Per-os-arch keys are populated by `publish-plugin.yml`'s build
# matrix — each cross-build artefact lands in `libs/<label>/`
# and the publish-time packer embeds every variant as a separate
# `wlift_sqlite__<label>` section the runtime extractor scores
# against the host. Bare-OS keys point at the flat `libs/`
# location so local `cargo build && cp target/release/...
# packages/hatch-sqlite/libs/` dev loops keep working —
# `resolve_for(os, arch)` tries the more-specific key first.
"macos-arm64"    = "libs/macos-arm64/libwlift_sqlite.dylib"
"macos-x86_64"   = "libs/macos-x86_64/libwlift_sqlite.dylib"
"linux-x86_64"   = "libs/linux-x86_64/libwlift_sqlite.so"
"linux-arm64"    = "libs/linux-arm64/libwlift_sqlite.so"
"windows-x86_64" = "libs/windows-x86_64/wlift_sqlite.dll"
macos            = "libs/libwlift_sqlite.dylib"
linux            = "libs/libwlift_sqlite.so"
windows          = "libs/wlift_sqlite.dll"

[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }