name        = "@hatch:game"
version     = "0.3.0"
entry       = "game"
description = "Game framework for Wren. `Game.run(MyGame)` and you're rendering — subclass `Game`, override `setup` / `update` / `draw`, get a window + GPU device + per-frame loop wired in. Composes with `@hatch:ecs` / `@hatch:assets` / `@hatch:audio` / `@hatch:physics` for the rest of a game. Same source drives a winit window on native and a page-attached canvas on web."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:game"
readme   = "README.md"

# In-workspace cross-package deps. Path entries keep the workspace
# self-contained — every sibling's `*.spec.wren` runs against the
# local copy without round-tripping through the registry. CI's
# publish workflow tags each package version separately; the
# in-tree `version =` line above is what gets used.
[dependencies]
"@hatch:window" = { path = "../hatch-window" }
"@hatch:gpu"    = { path = "../hatch-gpu" }
"@hatch:time"   = { path = "../hatch-time" }
"@hatch:math"   = { path = "../hatch-math" }
"@hatch:ecs"    = { path = "../hatch-ecs" }

[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }