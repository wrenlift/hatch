name        = "@hatch:game"
version     = "0.3.32"
entry       = "game"
description = "Game framework for Wren. `Game.run(MyGame)` and you're rendering — subclass `Game`, override `setup` / `update` / `draw`, get a window + GPU device + per-frame loop wired in. Composes with `@hatch:ecs` / `@hatch:assets` / `@hatch:audio` / `@hatch:physics` for the rest of a game. Same source drives a winit window on native and a page-attached canvas on web. Scene-level constructs: Transform / GlobalTransform, MeshRenderer, ParticleSystem, lights, physics bridges, SceneRenderer3D, Terrain, Foliage, Wind, Water mesh + wave-height sampler, and WaterPipeline — a self-contained render pipeline that displaces the water mesh on the GPU with the same wave field the CPU sampler uses, fresnel-blends to a sky colour, and adds Blinn-Phong specular on the wave crests."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:game"
readme   = "README.md"
changelog = "CHANGELOG.md"

# Search path for the wlift_particles dylib at spec / dev time. CI
# populates `libs/<label>/` from the `[plugin_source]` build, but
# local development can drop a freshly-built dylib here too:
#
#     cargo build -p wlift_particles --release
#     cp target/release/libwlift_particles.dylib hatch/packages/hatch-game/libs/
native_search_paths = ["libs"]

[plugin_source]
repo  = "https://github.com/wrenlift/WrenLift.git"
# Pin to the wren_lift rev that introduced the wlift_particles
# plugin. Bump when the plugin's `wlift_particles_*` C surface adds
# new entries the Wren-side wrapper needs.
rev   = "1166fdedb0ec723a8b915d90e1d6d40ad1f936cb"
crate = "wlift_particles"

[native_libs.wlift_particles]
# CI populates `libs/<label>/`; bare-OS keys are the local-dev
# fallback. See hatch-physics's manifest for the cross-target
# rationale.
"macos-arm64"    = "libs/macos-arm64/libwlift_particles.dylib"
"macos-x86_64"   = "libs/macos-x86_64/libwlift_particles.dylib"
"linux-x86_64"   = "libs/linux-x86_64/libwlift_particles.so"
"linux-arm64"    = "libs/linux-arm64/libwlift_particles.so"
"windows-x86_64" = "libs/windows-x86_64/wlift_particles.dll"
macos            = "libs/libwlift_particles.dylib"
linux            = "libs/libwlift_particles.so"
windows          = "libs/wlift_particles.dll"

# Cross-package deps. Version pins resolve through the registry,
# so the published bundle is fully self-describing.
#
# WORKSPACE OVERRIDE: @hatch:gpu is on a path dep so the in-tree
# `gpu_native.wren` + plugin dylib pick up locally during the
# shore-foam / depth-sample iteration. Revert this entry to the
# matching version pin (e.g. "0.3.9" after a publish) before
# publishing @hatch:game itself — path deps don't resolve for
# downstream consumers of the registry bundle.
[dependencies]
# Path dep so the in-tree `window_native.wren` (Window.setVisible /
# show / hide + open-hidden initial state) picks up locally during
# the lifecycle iteration. Revert to a version pin before publishing
# @hatch:game (path deps don't resolve for downstream consumers).
"@hatch:window" = "0.2.13"
"@hatch:gpu"    = "0.3.18"
"@hatch:time"   = "0.1.2"
"@hatch:math"   = "0.1.5"
"@hatch:ecs"    = "0.2.4"
# `Actions` uses an EventEmitter so statecharts can subscribe via
# `chart.bindEvents(Actions.emitter, [...])` — same shape every
# @hatch:fsm consumer already speaks.
"@hatch:events" = "0.2.2"
# Terrain module wraps @hatch:noise's batched fillSimplex2 to
# produce heightmap Meshes; everything else in @hatch:game can
# still be used without ever touching Terrain.
"@hatch:noise"  = "0.2.1"

[spec-dependencies]
"@hatch:test"   = "0.2.1"
"@hatch:assert" = "0.2.3"
# actions.spec validates the Actions × StateChart binding flow.
"@hatch:fsm"    = "0.1.2"
# particles.spec uses `Os.env("WLIFT_PERF")` to gate the 100k-
# billboard exit-gate benchmark (Phase 6d) — runs in seconds,
# would dominate the default `hatch test` time otherwise.
"@hatch:os"     = "0.1.2"