name        = "@hatch:game"
version     = "0.3.13"
entry       = "game"
description = "Game framework for Wren. `Game.run(MyGame)` and you're rendering — subclass `Game`, override `setup` / `update` / `draw`, get a window + GPU device + per-frame loop wired in. Composes with `@hatch:ecs` / `@hatch:assets` / `@hatch:audio` / `@hatch:physics` for the rest of a game. Same source drives a winit window on native and a page-attached canvas on web. Scene-level constructs: Transform / GlobalTransform, MeshRenderer, ParticleSystem, lights, physics bridges, SceneRenderer3D, Terrain (heightmap-driven mesh from @hatch:noise + @hatch:gpu), Foliage (jittered-grid scatter with optional density threshold), and Wind — deterministic 3D vector field driven by simplex3 with caller-controlled base direction, gust amplitude, and time evolution; drop into particle integrators, foliage sway, or any environmental force pipeline."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:game"
readme   = "README.md"

# Cross-package deps. Version pins resolve through the registry,
# so the published bundle is fully self-describing.
[dependencies]
"@hatch:window" = "0.2.11"
"@hatch:gpu"    = "0.3.8"
"@hatch:time"   = "0.1.2"
"@hatch:math"   = "0.1.5"
"@hatch:ecs"    = "0.2.4"
# `Actions` uses an EventEmitter so statecharts can subscribe via
# `chart.bindEvents(Actions.emitter, [...])` — same shape every
# @hatch:fsm consumer already speaks.
"@hatch:events" = "0.2.2"
# Terrain module wraps @hatch:noise's batched fillSimplex2 to
# produce heightmap Meshes; everything else in @hatch:game can
# still be used without ever touching Terrain.
"@hatch:noise"  = "0.1.0"

[spec-dependencies]
"@hatch:test"   = "0.2.1"
"@hatch:assert" = "0.2.3"
# actions.spec validates the Actions × StateChart binding flow.
"@hatch:fsm"    = "0.1.1"