name        = "@hatch:game"
version     = "0.2.4"
entry       = "game"
description = "The WrenLift game framework — `Game.run(MyGame)` and you're rendering. Wires `@hatch:window`, `@hatch:gpu`, `@hatch:time`, input, and a per-frame loop into a single subclass-and-go entry point; ships alongside `@hatch:ecs`, `@hatch:assets`, `@hatch:audio` (and friends) for the rest of a game's surface area. Native + web parity — same code drives a winit window or a page-attached canvas."

[dependencies]
"@hatch:window" = "0.2.4"
"@hatch:gpu"    = "0.2.4"
"@hatch:time"   = "0.1.0"
[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }