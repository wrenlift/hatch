name        = "@hatch:web"
version     = "0.1.0"
entry       = "web"
description = "Server-rendered, htmx-native web framework for Wren. Router, middleware, content-negotiated rendering via @hatch:template, HTTP/1.1 server on top of @hatch:socket."

# Explicit module list. Excludes examples/* (those have top-level
# `app.listen()` calls that would block the dep-install pass).
# Order matters: dependents come after their dependencies.
modules = ["css", "forms", "live", "web"]

[dependencies]
"@hatch:socket"   = { path = "../hatch-socket" }
"@hatch:template" = { path = "../hatch-template" }
"@hatch:log"      = { path = "../hatch-log" }
"@hatch:hash"     = { path = "../hatch-hash" }
"@hatch:json"     = { path = "../hatch-json" }
"@hatch:crypto"   = { path = "../hatch-crypto" }
"@hatch:fs"       = { path = "../hatch-fs" }
"@hatch:time"     = { path = "../hatch-time" }

[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }
"@hatch:http"   = { path = "../hatch-http" }
