name        = "@hatch:window"
version     = "0.2.7"
entry       = "window"
description = "Window + input for `@hatch:game` (and any consumer that wants its own window). winit on native, page-attached canvas on web — same `Window.create({...})` API, same `pollEvents` / `closeRequested` / `size` surface. Hands `@hatch:gpu` the handle it needs to build a Surface; bring-your-own canvas via `Window.attach(elementId)` on web."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:window"
readme   = "README.md"

native_search_paths = ["libs"]

[plugin_source]
repo      = "https://github.com/wrenlift/WrenLift.git"
rev       = "e02ffd76a7b78988be61bfb92076bbbeb592bb6d"
crate     = "wlift_window"
# Wasm-only companion cdylib for the browser path; produces
# `wlift_window_web.wasm` matching the `wasm = …` entry below.
web_crate = "wlift_window_web"

[native_libs.wlift_window]
# CI populates `libs/<label>/`; bare-OS keys are the local-dev
# fallback. See hatch-sqlite's manifest for the full rationale.
"macos-arm64"    = "libs/macos-arm64/libwlift_window.dylib"
"macos-x86_64"   = "libs/macos-x86_64/libwlift_window.dylib"
"linux-x86_64"   = "libs/linux-x86_64/libwlift_window.so"
"linux-arm64"    = "libs/linux-arm64/libwlift_window.so"
"windows-x86_64" = "libs/windows-x86_64/wlift_window.dll"
macos            = "libs/libwlift_window.dylib"
linux            = "libs/libwlift_window.so"
windows          = "libs/wlift_window.dll"
wasm             = "libs/wlift_window_web.wasm"

[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }