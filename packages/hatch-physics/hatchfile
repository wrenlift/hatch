name        = "@hatch:physics"
version     = "0.1.3"
entry       = "physics"
description = "Rapier-backed physics. `World2D` and `World3D` from one import — bodies, colliders, gravity, force / impulse, position + velocity reads. Bundles rapier2d + rapier3d in a single cdylib so games never have to choose between dimensions at the package level. Wires into `@hatch:game` for a step-per-frame physics loop."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:physics"
readme   = "README.md"

native_search_paths = ["libs"]

[plugin_source]
repo  = "https://github.com/wrenlift/WrenLift.git"
rev   = "ac32d4fdd8aa3db58aadfa2e6131bb77008059aa"
crate = "wlift_physics"

[native_libs.wlift_physics]
# CI populates `libs/<label>/`; bare-OS keys are the local-dev
# fallback. See hatch-sqlite's manifest for the full rationale.
"macos-arm64"    = "libs/macos-arm64/libwlift_physics.dylib"
"macos-x86_64"   = "libs/macos-x86_64/libwlift_physics.dylib"
"linux-x86_64"   = "libs/linux-x86_64/libwlift_physics.so"
"linux-arm64"    = "libs/linux-arm64/libwlift_physics.so"
"windows-x86_64" = "libs/windows-x86_64/wlift_physics.dll"
macos            = "libs/libwlift_physics.dylib"
linux            = "libs/libwlift_physics.so"
windows          = "libs/wlift_physics.dll"

[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }