name        = "@hatch:gpu-web"
version     = "0.1.0"
entry       = "gpu"
description = "WebGPU plugin for the WrenLift game framework. Wasm-only — JS-side bridge talks to navigator.gpu directly. Pairs with @hatch:gpu's native wgpu-backed cdylib for a per-target deployment story. Modern browsers only (Chrome 113+, Safari 17.4+, Firefox 141+); no WebGL2 fallback."

native_search_paths = ["libs"]

[plugin_source]
repo    = "https://github.com/wrenlift/WrenLift.git"
rev     = "main"
library = "wlift_gpu_web"

[native_libs]
wlift_gpu = { wasm = "libs/wlift_gpu_web.wasm" }

[dependencies]
"@hatch:window-web" = { path = "../hatch-window-web" }
