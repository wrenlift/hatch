name        = "@hatch:http"
version     = "0.3.2"
entry       = "http"
description = "HTTP/1.1 client with TLS, streaming bodies, and fiber-cooperative reads."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:http"
readme   = "README.md"

[dependencies]
# Bumped to 0.1.2 to match @hatch:web's transitive — the bundler
# rejects two versions of the same module in one dep graph, so
# downstream apps that pull both @hatch:web and @hatch:http
# (e.g. hatch.wrenlift.com calling out to Supabase from request
# handlers) couldn't resolve until both sides agreed on the json
# version. JSON.parse / JSON.encode surface unchanged across the
# bump.
"@hatch:json" = "0.1.2"
"@hatch:url"  = "0.1.0"
"@hatch:io"   = "0.2.0"
[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }