name        = "@hatch:http"
version     = "0.3.3"
entry       = "http"
description = "HTTP/1.1 client with TLS, streaming bodies, and fiber-cooperative reads."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:http"
readme   = "README.md"

[dependencies]
# 0.1.3 picks up the parser's `parseString_.intern` change: repeated
# JSON object keys collapse to one ObjString. Backed by the
# String.intern foreign method that ships with wren_lift's
# 8e93f89-era runtime. The bundle's transitive constraints stay
# consistent with @hatch:web (also tracked to 0.1.3); JSON.parse
# / JSON.encode surface unchanged across the bump.
"@hatch:json" = "0.1.3"
"@hatch:url"  = "0.1.0"
"@hatch:io"   = "0.2.0"
[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }