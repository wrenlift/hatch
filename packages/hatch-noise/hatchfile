name        = "@hatch:noise"
version     = "0.2.0"
entry       = "noise"
description = "Procedural noise primitives — 2D + 3D Simplex / Perlin / Value scalars, fractal Brownian motion octave-sum, and a batched Float32Array heightmap sampler. Backed by the `noise` crate so terrain generators, foliage scatter, weather simulations, and texture authoring all share the same deterministic, seeded implementations."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:noise"
readme      = "README.md"

native_search_paths = ["libs"]

[plugin_source]
repo  = "https://github.com/wrenlift/WrenLift.git"
crate = "wlift_noise"
# Bumped when the cdylib grows new `wlift_noise_*` exports — the
# Wren wrappers in noise.wren depend on those symbols being
# present at dlopen time.
rev   = "4afb174"

[native_libs.wlift_noise]
# CI populates `libs/<label>/` per-platform; bare-OS keys are the
# local-dev fallback for hand-copied builds (see hatch-image's
# manifest for the full rationale).
"macos-arm64"    = "libs/macos-arm64/libwlift_noise.dylib"
"macos-x86_64"   = "libs/macos-x86_64/libwlift_noise.dylib"
"linux-x86_64"   = "libs/linux-x86_64/libwlift_noise.so"
"linux-arm64"    = "libs/linux-arm64/libwlift_noise.so"
"windows-x86_64" = "libs/windows-x86_64/wlift_noise.dll"
macos            = "libs/libwlift_noise.dylib"
linux            = "libs/libwlift_noise.so"
windows          = "libs/wlift_noise.dll"

[spec-dependencies]
"@hatch:test"   = "0.2.1"
"@hatch:assert" = "0.2.3"
