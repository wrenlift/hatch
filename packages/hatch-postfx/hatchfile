name        = "@hatch:postfx"
version     = "0.1.0"
entry       = "postfx"
description = "Common post-processing effects for the WrenLift game framework. `Tonemap`, `Vignette`, `Bloom`, `FXAA`, `ColorGrade`, `ChromaticAberration` — each a `PostPass` subclass that drops into `g.postFX = PostFX.new(g)` from `@hatch:game`. Effects ship here so the engine stays lean; new effects can be added without bumping `@hatch:game`."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:postfx"
readme      = "README.md"

# `@hatch:game` provides the chain primitive (`PostFX` + `PostPass`)
# that every effect here subclasses. Path-dep during dev so the
# spec suite picks up the local refactor before publish; CI swaps
# to the registry version on release.
[dependencies]
# Path during development against the in-tree refactor; flip to
# `"@hatch:game" = "0.3.4"` at publish time so registry consumers
# resolve the bundled artifact.
"@hatch:game" = { path = "../hatch-game" }

[spec-dependencies]
"@hatch:test"   = "0.2.1"
"@hatch:assert" = "0.2.3"
