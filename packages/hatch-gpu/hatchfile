name        = "@hatch:gpu"
version     = "0.3.2"
entry       = "gpu"
description = "GPU primitives + 2D/3D renderers. Device, Buffer, Texture, Sampler, ShaderModule, BindGroup, RenderPipeline, CommandEncoder, RenderPass on the bottom; Camera2D/3D, Renderer2D (sprite batcher), Renderer3D (Cook-Torrance / GGX PBR with multi-light + textured metallic-roughness workflow), Shader factory, Mesh, Material on top. Same shared source drives wgpu on native and WebGPU on web."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:gpu"
readme   = "README.md"

# Search path for the dylib at spec / dev time. CI populates
# `libs/` from the `[plugin_source]` build, but local development
# can drop a freshly-built dylib here too:
#
#     cargo build -p wlift_gpu --release
#     cp target/release/libwlift_gpu.dylib hatch/packages/hatch-gpu/libs/
native_search_paths = ["libs"]

# @hatch:math — we reuse Vec3 / Mat4 / Quat via their public
# `.data` accessor for batched buffer uploads, no duplicated math
# API.
#
# `LivePipeline` references `@hatch:assets` in its docs, but the
# class itself just takes any duck-typed `db` with `.text(path)`
# — we don't import @hatch:assets here, so users who never touch
# LivePipeline don't pay the dep, and web users (who can't yet
# load a filesystem-backed assets db) can use the rest of the
# package without bringing in code that wouldn't run anyway.
[dependencies]
"@hatch:math" = "0.1.5"
# Where the cdylib lives. Same shape as @hatch:sqlite — clone
# `repo` at `rev`, run `cargo build -p wlift_gpu --release`
# across the platform matrix, drop each dylib into `libs/`,
# bundle via `hatch publish`.
[plugin_source]
repo      = "https://github.com/wrenlift/WrenLift.git"
# Bump tracks WrenLift's bundle-side `topo_sort_wren_files_by_imports`
# (commit 8a65fa0). Without it the published bundle listed
# `gpu_renderer3d` *before* `gpu_shader`, so when the runtime
# installed gpu_renderer3d it imported a not-yet-loaded sibling
# and `Shader` resolved to null. The plugin C surface is unchanged
# from e52ba41 — this rev only affects how `wlift` orders modules
# inside the .hatch bundle.
rev       = "05cbc54"
crate     = "wlift_gpu"
# Wasm-only companion cdylib used when the bundle runs in a
# browser. Built from the same `repo`/`rev`; produces
# `wlift_gpu_web.wasm` matching the `wasm = …` entry below.
web_crate = "wlift_gpu_web"

# Per-platform dylib paths. CI (publish-plugin.yml) populates
# `libs/<label>/` per matrix entry; bare-OS keys are the local-
# dev fallback for hand-copied builds. See hatch-sqlite's
# manifest for the full rationale.
[native_libs.wlift_gpu]
"macos-arm64"    = "libs/macos-arm64/libwlift_gpu.dylib"
"macos-x86_64"   = "libs/macos-x86_64/libwlift_gpu.dylib"
"linux-x86_64"   = "libs/linux-x86_64/libwlift_gpu.so"
"linux-arm64"    = "libs/linux-arm64/libwlift_gpu.so"
"windows-x86_64" = "libs/windows-x86_64/wlift_gpu.dll"
macos            = "libs/libwlift_gpu.dylib"
linux            = "libs/libwlift_gpu.so"
windows          = "libs/wlift_gpu.dll"
wasm             = "libs/wlift_gpu_web.wasm"

[spec-dependencies]
"@hatch:test" = "0.2.1"
"@hatch:assert" = "0.2.3"
# `gpu.spec.wren` exercises the LivePipeline path — it imports
# `@hatch:assets` directly. Declared here (not in [dependencies])
# so the runtime package stays minimal: users who never touch
# LivePipeline don't pull a filesystem-only dep through.
"@hatch:assets" = "0.2.2"
"@hatch:fs" = "0.1.2"
"@hatch:hash" = "0.1.1"