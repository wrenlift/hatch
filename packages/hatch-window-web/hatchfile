name        = "@hatch:window-web"
version     = "0.1.0"
entry       = "window"
description = "Browser-canvas window provider for the WrenLift game framework. Wasm-only — pairs with @hatch:window's native winit-backed cdylib for a per-target deployment story. Both expose the same foreign-method names so Wren-side code is target-agnostic; only the binary that ships in [native_libs] differs."

native_search_paths = ["libs"]

[plugin_source]
repo    = "https://github.com/wrenlift/WrenLift.git"
rev     = "main"
library = "wlift_window_web"

[native_libs]
wlift_window = { wasm = "libs/wlift_window_web.wasm" }
