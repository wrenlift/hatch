name        = "@hatch:image"
version     = "0.1.2"
entry       = "image"
description = "Image encode + decode. PNG / JPG / BMP / WebP in, RGBA8 buffer out — `Image.decode(bytes)` feeds straight into `@hatch:gpu`'s `Device.uploadImage(image)`, and `Image.encodePng(...)` writes synthesized buffers back out. Backed by the `image` crate."

native_search_paths = ["libs"]

[plugin_source]
repo  = "https://github.com/wrenlift/WrenLift.git"
rev   = "bb352b0ddc00aeeeb28268dc52a7437341c8e698"
crate = "wlift_image"

[native_libs]
wlift_image = { macos = "libs/libwlift_image.dylib", linux = "libs/libwlift_image.so", windows = "libs/wlift_image.dll" }

[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }