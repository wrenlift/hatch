name        = "@hatch:image"
version     = "0.1.5"
entry       = "image"
description = "Image encode + decode. PNG / JPG / BMP / WebP in, RGBA8 buffer out — `Image.decode(bytes)` feeds straight into `@hatch:gpu`'s `Device.uploadImage(image)`, and `Image.encodePng(...)` writes synthesized buffers back out. Backed by the `image` crate."
homepage    = "https://hatch.wrenlift.com/packages/@hatch:image"
readme   = "README.md"

native_search_paths = ["libs"]

[plugin_source]
repo  = "https://github.com/wrenlift/WrenLift.git"
rev   = "6c2e530"
crate = "wlift_image"

[native_libs.wlift_image]
# CI populates `libs/<label>/`; bare-OS keys are the local-dev
# fallback. See hatch-sqlite's manifest for the full rationale.
"macos-arm64"    = "libs/macos-arm64/libwlift_image.dylib"
"macos-x86_64"   = "libs/macos-x86_64/libwlift_image.dylib"
"linux-x86_64"   = "libs/linux-x86_64/libwlift_image.so"
"linux-arm64"    = "libs/linux-arm64/libwlift_image.so"
"windows-x86_64" = "libs/windows-x86_64/wlift_image.dll"
macos            = "libs/libwlift_image.dylib"
linux            = "libs/libwlift_image.so"
windows          = "libs/wlift_image.dll"

[spec-dependencies]
"@hatch:test"   = { path = "../hatch-test" }
"@hatch:assert" = { path = "../hatch-assert" }