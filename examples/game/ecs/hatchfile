name        = "ecs-asteroids"
version     = "0.1.0"
entry       = "main"
description = "ECS-driven asteroid field. Position + Velocity + Sprite components, two systems (motion + wrap), batched render. Showcases @hatch:ecs composing with @hatch:game."

# @hatch:gpu comes transitively through @hatch:game; declaring it
# again here trips the resolver's cycle detector.
[dependencies]
"@hatch:game"  = { path = "../../../packages/hatch-game" }
"@hatch:ecs"   = { path = "../../../packages/hatch-ecs" }
"@hatch:image" = { path = "../../../packages/hatch-image" }
