name        = "toon-shading"
version     = "0.1.0"
entry       = "main"
description = "Cel-shaded sphere trio comparing band counts and rim strength against a PBR ground for reference. Demonstrates Material.shadingModel = \"toon\" plus the bands / rimStrength / rimWidth / ambientFloor dials on @hatch:gpu's Renderer3D."

# @hatch:gpu and @hatch:math come transitively through
# @hatch:game; redeclaring them here collides on shared modules.
#
# Dual-form dep — `path` is tried first; if it doesn't resolve
# (typical when a consumer clones a publish bundle without the
# workspace checkout) the resolver falls back to the registry
# `version` pin. The example builds in both contexts.
[dependencies]
"@hatch:game" = { path = "../../../packages/hatch-game", version = "0.3.36" }
