name        = "procedural-world"
version     = "0.1.0"
entry       = "main"
description = "Procedural terrain + animated water + instanced foliage with live HUD controls. Composes every phase shipped on the procedural-world parity track: @hatch:noise drives terrain heights and foliage density, Terrain.fromNoise builds the ground mesh, Foliage.scatter picks placement points, ClusterGrid + Frustum.sphereVisible + Lod.select3 cull and bucket the visible subset, Renderer3D.drawMeshInstanced renders each LOD in one drawIndexed, WaterPipeline paints the lake with animated displacement, and HUDPanel exposes every knob (water amplitude, wind gust, foliage density, fov) at runtime."

# Dual-form deps — `path` is tried first (workspace dev), with
# the registry `version` pin as the publish fallback. Aligned to
# the same workspace versions every other downstream picks, so
# the bundle merger sees identical bytes for shared transitive
# modules and no `module X collides with the enclosing hatch`
# error fires.
[dependencies]
"@hatch:game"    = { path = "../../../packages/hatch-game",    version = "0.3.37" }
"@hatch:hud"     = { path = "../../../packages/hatch-hud",     version = "0.1.7" }
"@hatch:gpu"     = { path = "../../../packages/hatch-gpu",     version = "0.3.22" }
"@hatch:spatial" = { path = "../../../packages/hatch-spatial", version = "0.2.1" }
"@hatch:assets"  = { path = "../../../packages/hatch-assets",  version = "0.2.6" }
"@hatch:image"   = { path = "../../../packages/hatch-image",   version = "0.1.9" }
"@hatch:gltf"    = { path = "../../../packages/hatch-gltf",    version = "0.1.3" }
"@hatch:postfx"  = { path = "../../../packages/hatch-postfx",  version = "0.2.0" }
