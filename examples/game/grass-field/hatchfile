name        = "grass-field"
version     = "0.1.0"
entry       = "main"
description = "Cel-shaded grass field — 5,000 toon-shaded blades scattered via Foliage.scatter, rendered through a single drawMeshInstanced, swaying in the wind via the vertex-stage `apply_sway` term in @hatch:gpu's instanced shader. Camera orbits so you can read the wind direction as the field bends."

# Dual-form dep — `path` is tried first; if it doesn't resolve
# (typical when a consumer clones a publish bundle without the
# workspace checkout) the resolver falls back to the registry
# `version` pin. The example builds in both contexts.
[dependencies]
"@hatch:game" = { path = "../../../packages/hatch-game", version = "0.3.36" }
